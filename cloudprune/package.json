{
  "name": "cloudprune",
  "version": "0.1.0",
  "private": true,
  "description": "CloudPrune cloud cost monitoring and savings workspace.",
  "scripts": {
    "assess:aws": "npm run build --silent && node dist/scripts/aws-assessment.js",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-build-assets.js",
    "clean": "rm -rf dist",
    "dev": "npm run build && node dist/server.js",
    "growth:followup": "node scripts/followup-growth-shortlist.js",
    "growth:resources": "node scripts/generate-growth-resource-pages.js",
    "growth:shortlist": "python3 scripts/cloudprune_growth_shortlist.py",
    "start": "node dist/server.js",
    "test": "npm run build && node --test",
    "typecheck": "tsc --noEmit",
    "check": "node --check cloudprune/app.js && node --check scripts/aws-assessment.js && node --check scripts/copy-build-assets.js && npm run typecheck && npm run clean && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "puppeteer-core": "^25.3.0",
    "typescript": "^6.0.3"
  }
}
